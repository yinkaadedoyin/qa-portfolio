{
  "info": {
    "name": "Account & Transaction API Tests",
    "description": "Sample Postman collection testing account balance and transaction history endpoints for a banking API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Balance - Valid Account",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/accounts/{{accountId}}/balance",
          "host": ["{{baseUrl}}"],
          "path": ["accounts", "{{accountId}}", "balance"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has balance field of type number', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('balance');",
              "    pm.expect(jsonData.balance).to.be.a('number');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Balance - Missing Auth Token",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/accounts/{{accountId}}/balance",
          "host": ["{{baseUrl}}"],
          "path": ["accounts", "{{accountId}}", "balance"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 401 without auth token', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Balance - Invalid Account ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/accounts/invalid-id-000/balance",
          "host": ["{{baseUrl}}"],
          "path": ["accounts", "invalid-id-000", "balance"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404 for invalid account', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Transactions - Default Pagination",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/accounts/{{accountId}}/transactions",
          "host": ["{{baseUrl}}"],
          "path": ["accounts", "{{accountId}}", "transactions"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Transactions - Invalid Page Parameter",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/accounts/{{accountId}}/transactions?page=-1",
          "host": ["{{baseUrl}}"],
          "path": ["accounts", "{{accountId}}", "transactions"],
          "query": [
            { "key": "page", "value": "-1" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 400 for invalid page parameter', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "https://api.example-bank-staging.com/v1" },
    { "key": "accountId", "value": "acc_12345" },
    { "key": "authToken", "value": "your-token-here" }
  ]
}
